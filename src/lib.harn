  }
  if method == "views.update" {
    let view_id = __required_id(args, "view_id", "views.update")
    if is_err(view_id) {
      return view_id
    }
    return __sdk_result(
      try {
      update_a_view(__sdk_client(cfg), unwrap(view_id), __call_body(args))
    },
    )
  }
  if method == "views.delete" {
    let view_id = __required_id(args, "view_id", "views.delete")
    if is_err(view_id) {
