    )
    },
    )
  }
  if method == "data_sources.templates.list" {
    let data_source_id = __required_id(args, "data_source_id", "data_sources.templates.list")
    if is_err(data_source_id) {
      return data_source_id
    }
    return __sdk_result(
      try {
      list_data_source_templates(
      __sdk_client(cfg),
      unwrap(data_source_id),
      args?.name,
      args?.start_cursor,
      args?.page_size,
    )
    },
    )
  }
  if method == "blocks.children.append" {
    let block_id = args?.block_id ?? args?.page_id ?? args?.id
    if block_id == nil || block_id == "" {
      return __err("invalid_args", "blocks.children.append requires block_id")
    }
    var body = __call_body(args)
    if body?.children == nil && args?.blocks != nil {
      body.children = args.blocks
    }
    return __sdk_result(
      try {
      patch_block_children(__sdk_client(cfg), block_id, body)
    },
    )
  }
  if method == "search.query" {
    return __sdk_result(
      try {
      post_search(__sdk_client(cfg), __call_body(args))
    },
    )
  }
  if method == "comments.create" {
    let body = __call_body(args)
    let variant = if body?.markdown != nil {
      create_a_comment_variant2(body.markdown, body?.parent ?? {})
    } else {
      if body?.discussion_id != nil {
        create_a_comment_variant3(body.discussion_id, body?.rich_text ?? [])
      } else {
        create_a_comment_variant1(body?.parent ?? {}, body?.rich_text ?? [])
      }
    }
    return __sdk_result(
      try {
      create_a_comment(__sdk_client(cfg), variant)
    },
    )
  }
  if method == "comments.list" {
    return __sdk_result(
      try {
      list_comments(__sdk_client(cfg), args?.block_id, args?.start_cursor, args?.page_size)
    },
    )
  }
  if method == "comments.retrieve" {
    let comment_id = __required_id(args, "comment_id", "comments.retrieve")
    if is_err(comment_id) {
      return comment_id
    }
    return __sdk_result(
      try {
      retrieve_comment(__sdk_client(cfg), unwrap(comment_id))
    },
    )
  }
  if method == "comments.update" {
    let comment_id = __required_id(args, "comment_id", "comments.update")
    if is_err(comment_id) {
      return comment_id
    }
    return __sdk_result(
      try {
      update_a_comment(__sdk_client(cfg), unwrap(comment_id), __call_body(args))
    },
    )
  }
  if method == "comments.delete" {
    let comment_id = __required_id(args, "comment_id", "comments.delete")
    if is_err(comment_id) {
      return comment_id
    }
    return __sdk_result(
      try {
      delete_a_comment(__sdk_client(cfg), unwrap(comment_id))
    },
    )
  }
  if method == "custom_emojis.list" {
    return __sdk_result(
      try {
      list_custom_emojis(__sdk_client(cfg), args?.start_cursor, args?.page_size, args?.name)
    },
    )
  }
  if method == "file_uploads.list" {
    return __sdk_result(
      try {
      list_file_uploads(__sdk_client(cfg), args?.status, args?.start_cursor, args?.page_size)
    },
    )
  }
  if method == "file_uploads.create" {
    return __sdk_result(
      try {
      create_file(__sdk_client(cfg), __call_body(args))
    },
    )
  }
  if method == "file_uploads.retrieve" {
    let file_upload_id = __required_id(args, "file_upload_id", "file_uploads.retrieve")
    if is_err(file_upload_id) {
