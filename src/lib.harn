/** Return this connector's Harn provider id. */
pub fn provider_id() {
  return NOTION_PROVIDER_ID
}

/** Return the trigger kinds supported by this connector. */
pub fn kinds() {
  return ["webhook", "poll"]
}

/** Return the canonical normalized Notion event payload schema. */
pub fn payload_schema() {
  return {
    harn_schema_name: "NotionEventPayload",
    json_schema: {
    type: "object",
    required: ["provider", "event", "event_type", "resource_id", "raw"],
    additionalProperties: true,
    properties: {
    provider: {const: "notion"},
    event: {type: "string"},
    event_type: {type: "string"},
    workspace_id: {type: ["string", "null"]},
    request_id: {type: ["string", "null"]},
    subscription_id: {type: ["string", "null"]},
    integration_id: {type: ["string", "null"]},
    attempt_number: {type: ["integer", "null"]},
    entity_id: {type: ["string", "null"]},
    entity_type: {type: ["string", "null"]},
    api_version: {type: ["string", "null"]},
    verification_token: {type: ["string", "null"]},
    resource_id: {type: "string"},
    parent_id: {type: ["string", "null"]},
    actor: {
    type: "object",
    required: ["id", "name"],
    properties: {id: {type: ["string", "null"]}, name: {type: ["string", "null"]}},
  },
    occurred_at: {type: ["string", "null"]},
    polled: {type: ["object", "null"]},
    raw: {type: "object"},
  },
  },
  }
}

/** Initialize connector state with orchestrator context. */
pub fn init(ctx = nil) {
  let next = __default_state() + {initialized: true, ctx: ctx ?? {}}
  __set_state(next)
  return next
}

/** Activate webhook and poll bindings, storing normalized binding config. */
pub fn activate(bindings = []) {
  var webhook_bindings = {}
  var poll_bindings = {}
  var seen_paths = {}
  for binding in bindings ?? [] {
    let binding_id = binding?.binding_id ?? binding?.id ?? "binding-"
      + to_string(len(webhook_bindings.keys()) + len(poll_bindings.keys()))
    let kind = binding?.kind ?? binding?.source?.kind ?? binding?.config?.kind ?? "webhook"
    let normalized = binding + {binding_id: binding_id, kind: kind}
    if kind == "webhook" {
      let path = binding?.path ?? binding?.match?.path ?? binding?.config?.match?.path
      if path != nil && path != "" {
        if seen_paths.get(path) {
          return __err("activation", "notion connector path `" + path + "` is configured by multiple bindings")
        }
        seen_paths[path] = true
      }
      webhook_bindings[binding_id] = normalized
    } else if kind == "poll" {
      let poll = __normalize_poll_binding(normalized)
      if is_err(poll) {
        return poll
      }
      poll_bindings[binding_id] = unwrap(poll)
    } else {
      return __err("activation", "unsupported notion binding kind `" + to_string(kind) + "`")
    }
  }
  let next = __state()
    + {active: true, webhook_bindings: webhook_bindings, poll_bindings: poll_bindings}
  __set_state(next)
  return {
    provider: NOTION_PROVIDER_ID,
    kinds: ["webhook", "poll"],
    bindings: len(webhook_bindings.keys()) + len(poll_bindings.keys()),
    webhook_bindings: len(webhook_bindings.keys()),
    poll_bindings: len(poll_bindings.keys()),
  }
}

/** Clear connector lifecycle state. */
pub fn shutdown() {
  NOTION_STATE = __default_state()
  return {provider: NOTION_PROVIDER_ID, active: false}
}

@complexity(allow)
/**
 * Verify and normalize a raw Notion webhook body into NormalizeResult v1.
 *
 * Notion sends webhook JSON as UTF-8. Until Harn exposes raw body bytes to
 * pure-Harn connectors, signature verification intentionally uses
 * raw.body_text and rejects callers that only provide a parsed body.
 */
pub fn normalize_inbound(raw) {
  let body_text = __body_text(raw)
  if is_err(body_text) {
    return __reject_err(unwrap_err(body_text))
  }
  let parsed = try {
    json_parse(unwrap(body_text))
  }
  if is_err(parsed) {
    return __reject(400, "invalid_json", "notion payload body is not valid JSON")
  }
  let payload = unwrap(parsed)
  if payload?.verification_token != nil && trim(to_string(payload.verification_token)) != "" {
    let event = __build_event("subscription.verification", payload, raw, "unsigned")
    return {type: "event", event: event}
  }
  let verified = __verify_notion_signature(raw, raw?.headers ?? {}, unwrap(body_text))
  if is_err(verified) {
    return __reject_err(unwrap_err(verified))
  }
  let event = __build_event(payload?.type ?? "notion.webhook", payload, raw, "verified")
  return {type: "event", event: event}
}

@complexity(allow)
/** Dispatch a supported Notion API method with explicit method-to-path mapping. */
pub fn call(method, args = {}) {
  if !contains(NOTION_OUTBOUND_METHODS, method) {
    return __err("method_not_found", "notion connector does not implement outbound method `" + method + "`")
  }
  let config = __outbound_config(args ?? {})
  if is_err(config) {
    return config
  }
  let cfg = unwrap(config)
  if method == "blocks.retrieve" {
    let block_id = __required_id(args, "block_id", "blocks.retrieve")
    if is_err(block_id) {
      return block_id
    }
    return __sdk_result(
      try {
      retrieve_a_block(__sdk_client(cfg), unwrap(block_id))
    },
    )
  }
  if method == "blocks.update" {
    let block_id = __required_id(args, "block_id", "blocks.update")
    if is_err(block_id) {
      return block_id
    }
    return __sdk_result(
      try {
      update_a_block(__sdk_client(cfg), unwrap(block_id), __call_body(args))
    },
    )
  }
  if method == "blocks.delete" {
    let block_id = __required_id(args, "block_id", "blocks.delete")
    if is_err(block_id) {
      return block_id
    }
    return __sdk_result(
      try {
      delete_a_block(__sdk_client(cfg), unwrap(block_id))
    },
    )
  }
  if method == "blocks.children.list" {
    let block_id = __required_id(args, "block_id", "blocks.children.list")
    if is_err(block_id) {
      return block_id
    }
    return __sdk_result(
      try {
      get_block_children(__sdk_client(cfg), unwrap(block_id), args?.start_cursor, args?.page_size)
    },
    )
  }
  if method == "pages.retrieve" {
    let page_id = __required_id(args, "page_id", "pages.retrieve")
    if is_err(page_id) {
      return page_id
    }
    return __sdk_result(
      try {
      retrieve_a_page(__sdk_client(cfg), unwrap(page_id), args?.filter_properties)
    },
    )
  }
  if method == "pages.create" {
    return __sdk_result(
      try {
      post_page(__sdk_client(cfg), __call_body(args))
    },
    )
  }
  if method == "pages.update" {
    let page_id = __required_id(args, "page_id", "pages.update")
    if is_err(page_id) {
      return page_id
    }
    return __sdk_result(
