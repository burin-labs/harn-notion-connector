  if method == "databases.query" {
    let database_id = __required_id(args, "database_id", "databases.query")
    if is_err(database_id) {
      return database_id
    }
    return __notion_request(
      "POST",
      __notion_api_url(
      cfg.api_base_url,
      "/databases/" + url_encode(to_string(unwrap(database_id))) + "/query",
    ),
      __call_body(args),
      cfg,
    )
  }
  if method == "data_sources.create" {
    return __sdk_result(
      try {
      create_a_database(__sdk_client(cfg), __call_body(args))
    },
    )
  }
  if method == "data_sources.retrieve" {
    let data_source_id = __required_id(args, "data_source_id", "data_sources.retrieve")
