    )
  }
  if method == "pages.markdown.retrieve" {
    let page_id = __required_id(args, "page_id", "pages.markdown.retrieve")
    if is_err(page_id) {
      return page_id
    }
    return __sdk_result(
      try {
      retrieve_page_markdown(__sdk_client(cfg), unwrap(page_id), args?.include_transcript)
    },
    )
  }
  if method == "pages.markdown.update" {
    let page_id = __required_id(args, "page_id", "pages.markdown.update")
    if is_err(page_id) {
      return page_id
    }
    return __sdk_result(
      try {
      update_page_markdown(__sdk_client(cfg), unwrap(page_id), __call_body(args))
    },
    )
  }
  if method == "pages.move" {
    let page_id = __required_id(args, "page_id", "pages.move")
    if is_err(page_id) {
      return page_id
    }
    return __sdk_result(
      try {
      move_page(__sdk_client(cfg), unwrap(page_id), __call_body(args))
    },
    )
  }
  if method == "pages.properties.retrieve" {
    let page_id = __required_id(args, "page_id", "pages.properties.retrieve")
    if is_err(page_id) {
      return page_id
    }
    let property_id = __required_id(args, "property_id", "pages.properties.retrieve")
    if is_err(property_id) {
      return property_id
    }
    return __sdk_result(
      try {
      retrieve_a_page_property(
      __sdk_client(cfg),
      unwrap(page_id),
      unwrap(property_id),
      args?.start_cursor,
      args?.page_size,
    )
    },
    )
  }
  if method == "databases.create" {
    return __sdk_result(
      try {
      create_database(__sdk_client(cfg), __call_body(args))
    },
    )
  }
  if method == "databases.retrieve" {
    let database_id = __required_id(args, "database_id", "databases.retrieve")
    if is_err(database_id) {
      return database_id
    }
    return __sdk_result(
