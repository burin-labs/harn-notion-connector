      args?.database_id,
      args?.data_source_id,
      args?.start_cursor,
      args?.page_size,
    )
    },
    )
  }
  if method == "views.create" {
    return __sdk_result(
      try {
      create_view(__sdk_client(cfg), __call_body(args))
    },
    )
  }
  if method == "views.retrieve" {
    let view_id = __required_id(args, "view_id", "views.retrieve")
    if is_err(view_id) {
      return view_id
    }
    return __sdk_result(
      try {
      retrieve_a_view(__sdk_client(cfg), unwrap(view_id))
    },
