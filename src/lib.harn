    if is_err(file_upload_id) {
      return file_upload_id
    }
    return __sdk_result(
      try {
      complete_file_upload(__sdk_client(cfg), unwrap(file_upload_id))
    },
    )
  }
  if method == "file_uploads.send" {
    let file_upload_id = __required_id(args, "file_upload_id", "file_uploads.send")
    if is_err(file_upload_id) {
      return file_upload_id
    }
    return __sdk_result(
      try {
      upload_file(__sdk_client(cfg), unwrap(file_upload_id), __call_body(args))
    },
    )
  }
  if method == "users.list" {
    return __sdk_result(
      try {
      get_users(__sdk_client(cfg), args?.start_cursor, args?.page_size)
    },
    )
  }
  if method == "users.me" {
    return __sdk_result(
      try {
      get_self(__sdk_client(cfg))
    },
    )
  }
  if method == "users.retrieve" {
    let user_id = __required_id(args, "user_id", "users.retrieve")
    if is_err(user_id) {
      return user_id
    }
    return __sdk_result(
      try {
      get_user(__sdk_client(cfg), unwrap(user_id))
    },
