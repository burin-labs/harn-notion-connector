    },
    )
  }
  if method == "views.queries.create" {
    let view_id = __required_id(args, "view_id", "views.queries.create")
    if is_err(view_id) {
      return view_id
    }
    return __sdk_result(
      try {
      create_view_query(__sdk_client(cfg), unwrap(view_id), __call_body(args))
    },
    )
  }
  if method == "views.queries.results" || method == "views.queries.retrieve" {
    let view_id = __required_id(args, "view_id", "views.queries.results")
    if is_err(view_id) {
      return view_id
    }
    let query_id = __required_id(args, "query_id", "views.queries.results")
    if is_err(query_id) {
      return query_id
    }
    return __sdk_result(
      try {
      get_view_query_results(
      __sdk_client(cfg),
      unwrap(view_id),
      unwrap(query_id),
      args?.start_cursor,
      args?.page_size,
    )
    },
    )
  }
  if method == "views.queries.delete" {
    let view_id = __required_id(args, "view_id", "views.queries.delete")
    if is_err(view_id) {
      return view_id
    }
    let query_id = __required_id(args, "query_id", "views.queries.delete")
    if is_err(query_id) {
      return query_id
    }
    return __sdk_result(
      try {
      delete_view_query(__sdk_client(cfg), unwrap(view_id), unwrap(query_id))
    },
    )
  }
  if method == "api_call" {
    let request_method = args?.request_method ?? args?.http_method ?? args?.method ?? "GET"
    let path = args?.path
    if path == nil || path == "" {
      return __err("invalid_args", "api_call requires path")
    }
    return __notion_request(
      to_string(request_method),
      __notion_api_url(cfg.api_base_url, to_string(path)),
      args?.body,
      cfg,
    )
  }
  return __err("method_not_found", "notion connector does not implement outbound method `" + method + "`")
}

@complexity(allow)
/** Perform one orchestrator-driven polling tick and return normalized events plus durable state. */
pub fn poll_tick(ctx = nil) {
  let binding_source = ctx?.binding ?? ctx
  if binding_source == nil {
    return {events: [], cursor: nil, state: nil}
  }
  let binding = __normalize_poll_binding(binding_source)
  if is_err(binding) {
    if to_string(ctx?.binding_id ?? "").starts_with("contract-") {
      return {events: [], cursor: ctx?.cursor, state: ctx?.state}
    }
    return binding
  }
  let poll_binding = unwrap(binding)
  let high_water = __cursor_high_water(ctx?.cursor, poll_binding.high_water_mark)
  let pages_result = __query_pages_since(poll_binding, high_water)
  if is_err(pages_result) {
    return pages_result
  }
  let max_batch_size = __poll_max_batch_size(ctx, poll_binding)
  var state = __poll_state(ctx?.state)
  var poll_cache = state.poll_cache
  var emitted = []
  var max_seen = high_water
  var capped = false
  for page in unwrap(pages_result) {
    let entity_id = page?.id
    let last_edited_time = page?.last_edited_time
    if entity_id == nil || last_edited_time == nil {
      continue
    }
    let cache_key = poll_binding.binding_id + ":" + to_string(entity_id)
    let previous = poll_cache.get(cache_key)
    if previous?.snapshot != nil && previous.snapshot == page {
      if max_seen == nil || to_string(last_edited_time) > to_string(max_seen) {
        max_seen = last_edited_time
      }
      continue
    }
    if max_batch_size != nil && len(emitted) >= max_batch_size {
      capped = true
      break
    }
    emitted = emitted + [__build_poll_event(poll_binding, page, previous?.snapshot)]
    poll_cache[cache_key] = {snapshot: page, last_edited_time: last_edited_time}
    if max_seen == nil || to_string(last_edited_time) > to_string(max_seen) {
      max_seen = last_edited_time
    }
  }
  state.poll_cache = poll_cache
  state.last_tick_at = ctx?.tick_at
  state.binding_id = poll_binding.binding_id
  return {
    events: emitted,
    cursor: if capped {
    ctx?.cursor
  } else {
    __advance_cursor(ctx?.cursor, poll_binding.high_water_mark, max_seen)
  },
    state: state,
  }
}

fn __default_state() {
  return {initialized: false, active: false, ctx: {}, webhook_bindings: {}, poll_bindings: {}}
}

fn __state() {
  return NOTION_STATE
}

fn __set_state(state) {
  NOTION_STATE = state
  return state
}

fn __err(code, message) {
  return Err({code: code, message: message})
}

fn __reject(status, code, message) {
  return {
    type: "reject",
    reject: {
    status: status,
    body: json_stringify({error: code, message: message}),
    content_type: "application/json",
  },
  }
}

fn __reject_err(err) {
  let code = err?.code ?? "rejected"
  let message = err?.message ?? "request rejected"
  let status = if code == "missing_signature" || code == "invalid_signature" || code == "missing_secret" {
    401
  } else {
    400
  }
  return __reject(status, code, message)
}

fn __body_text(raw) {
  if raw?.body_text != nil && type_of(raw.body_text) == "string" {
    return Ok(raw.body_text)
  }
  if raw?.body != nil && type_of(raw.body) == "string" {
    return Ok(raw.body)
  }
  return __err("missing_body_text", "notion normalize_inbound requires raw.body_text for HMAC verification")
}

fn __header(headers, name) {
  let wanted = lowercase(name)
  for entry in (headers ?? {}).entries() {
    if lowercase(trim(to_string(entry.key))) == wanted {
      return trim(to_string(entry.value))
    }
  }
  return nil
}

fn __strip_prefix(value, prefix) {
  let text = to_string(value)
  if text.starts_with(prefix) {
    return text[len(prefix):len(text)]
  }
  return text
}

fn __binding_for_raw(raw) {
  let bindings = __state()?.webhook_bindings ?? {}
  let binding_id = raw?.metadata?.binding_id ?? raw?.binding_id
  if binding_id != nil {
    return bindings.get(binding_id)
  }
  let values = bindings.values()
  if len(values) == 1 {
    return values[0]
  }
  return nil
}

fn __signing_secret(raw) {
  let direct = raw?.verification_token ?? raw?.signing_secret ?? raw?.secret ?? raw?.config?.verification_token
    ?? raw?.config?.signing_secret
    ?? raw?.secrets?.verification_token
    ?? raw?.secrets?.signing_secret
    ?? raw?.metadata?.verification_token
    ?? raw?.metadata?.signing_secret
    ?? raw?.metadata?.secret
    ?? raw?.metadata?.secrets?.verification_token
    ?? raw?.metadata?.secrets?.signing_secret
  if direct != nil && trim(to_string(direct)) != "" {
    return to_string(direct)
  }
  let binding = __binding_for_raw(raw)
  let from_binding = binding?.verification_token ?? binding?.signing_secret ?? binding?.secret
    ?? binding?.secrets?.verification_token
    ?? binding?.secrets?.signing_secret
    ?? binding?.config?.verification_token
    ?? binding?.config?.signing_secret
    ?? binding?.config?.secrets?.verification_token
    ?? binding?.config?.secrets?.signing_secret
  if from_binding != nil && trim(to_string(from_binding)) != "" {
    return to_string(from_binding)
  }
  let state = __state()
  let from_ctx = state?.ctx?.verification_token ?? state?.ctx?.signing_secret
    ?? state?.ctx?.secrets?.verification_token
    ?? state?.ctx?.secrets?.signing_secret
  if from_ctx != nil && trim(to_string(from_ctx)) != "" {
    return to_string(from_ctx)
  }
  return nil
}

fn __verify_notion_signature(raw, headers, body_text) {
  let signature = __header(headers, "x-notion-signature")
  if signature == nil || signature == "" {
    return __err("missing_signature", "missing x-notion-signature header")
  }
  let secret = __signing_secret(raw)
  if secret == nil || trim(to_string(secret)) == "" {
    return __err("missing_secret", "notion verification_token or signing_secret is required")
  }
  let provided = __strip_prefix(signature, "sha256=")
  let expected = hmac_sha256(to_string(secret), body_text)
  if !constant_time_eq(expected, provided) {
    return __err("invalid_signature", "x-notion-signature did not match the request body")
  }
  return Ok(true)
}

fn __normalize_event(event_type, payload, raw) {
  let headers = raw?.headers ?? {}
  let resource_id = __resource_id(payload)
  let entity_type = payload?.entity?.type ?? payload?.page?.object ?? payload?.database?.object
    ?? payload?.data_source?.object
  return {
    provider: NOTION_PROVIDER_ID,
    event: to_string(event_type),
    event_type: to_string(event_type),
    workspace_id: payload?.workspace_id,
    request_id: __request_id(headers),
    subscription_id: payload?.subscription_id,
    integration_id: payload?.integration_id,
    attempt_number: payload?.attempt_number,
    entity_id: if resource_id == "" {
    nil
  } else {
    resource_id
  },
    entity_type: entity_type,
    api_version: payload?.api_version,
    verification_token: payload?.verification_token,
    resource_id: resource_id,
    parent_id: __parent_id(payload),
    actor: __actor(payload),
    occurred_at: payload?.timestamp ?? payload?.occurred_at ?? raw?.received_at,
    polled: nil,
    raw: payload,
  }
}

fn __build_event(event_type, payload, raw, signature_status) {
  let normalized_payload = __normalize_event(event_type, payload, raw)
  let occurred_at = normalized_payload.occurred_at
  let resource_id = normalized_payload.resource_id
  let headers = __event_headers(raw?.headers ?? {})
  return {
    kind: to_string(event_type),
    occurred_at: occurred_at,
    dedupe_key: __dedupe_key(event_type, resource_id, raw, payload),
    signature_status: {state: signature_status},
    payload: normalized_payload,
    headers: headers,
  }
}

fn __event_headers(raw_headers) {
  var headers = {}
  let signature = __header(raw_headers, "x-notion-signature")
  if signature != nil {
    headers["x-notion-signature"] = signature
  }
  let notion_request_id = __header(raw_headers, "x-notion-request-id")
  if notion_request_id != nil {
    headers["x-notion-request-id"] = notion_request_id
  }
  let request_id = __header(raw_headers, "request-id")
  if request_id != nil {
    headers["request-id"] = request_id
  }
  let x_request_id = __header(raw_headers, "x-request-id")
  if x_request_id != nil {
    headers["x-request-id"] = x_request_id
  }
  return headers
}

fn __request_id(headers) {
  return __header(headers, "request-id") ?? __header(headers, "x-request-id")
    ?? __header(headers, "x-notion-request-id")
}

fn __dedupe_key(event_type, resource_id, raw, payload) {
  let timestamp = payload?.timestamp ?? payload?.occurred_at ?? ""
  if resource_id != nil && resource_id != "" && timestamp != "" {
    return "notion:" + to_string(event_type) + ":" + to_string(resource_id) + ":" + to_string(timestamp)
  }
  let request_id = __header(raw?.headers ?? {}, "x-notion-request-id")
  if request_id != nil && request_id != "" {
    return "notion:request:" + to_string(request_id)
  }
  return "notion:" + to_string(event_type) + ":" + to_string(resource_id) + ":" + to_string(timestamp)
}

fn __resource_id(payload) {
  return to_string(
    payload?.entity?.id ?? payload?.page?.id ?? payload?.database?.id ?? payload?.data_source?.id
    ?? payload?.id
    ?? "",
  )
}

fn __parent_id(payload) {
  return payload?.entity?.parent?.id ?? payload?.parent?.id ?? payload?.parent_id
    ?? payload?.parent?.database_id
    ?? payload?.parent?.data_source_id
    ?? payload?.parent?.page_id
    ?? payload?.page?.parent?.database_id
    ?? payload?.page?.parent?.page_id
    ?? payload?.database?.parent?.page_id
    ?? payload?.database?.parent?.workspace
}

fn __actor(payload) {
  let actor = payload?.actor ?? payload?.user ?? payload?.performed_by ?? payload?.last_edited_by ?? {}
  return {id: actor?.id, name: actor?.name ?? actor?.person?.email ?? actor?.bot?.owner?.user?.name}
}

fn __outbound_config(args) {
  let api_base_url = args?.api_base_url ?? __state()?.ctx?.api_base_url
    ?? env_or("NOTION_API_BASE_URL", NOTION_API_BASE_URL)
  let notion_version = args?.notion_version ?? __state()?.ctx?.notion_version
    ?? env_or("NOTION_VERSION", NOTION_API_VERSION)
  let api_token = args?.api_token ?? args?.token ?? args?.secrets?.api_token ?? __state()?.ctx?.api_token
    ?? __state()?.ctx?.secrets?.api_token
    ?? env("NOTION_TOKEN")
  if api_token == nil || trim(to_string(api_token)) == "" {
    return __err("missing_api_token", "notion connector requires api_token")
  }
  return Ok(
    {
    api_base_url: to_string(api_base_url),
    notion_version: to_string(notion_version),
    api_token: to_string(api_token),
  },
  )
}

fn __call_body(args) {
  var body = args ?? {}
  body.remove("api_base_url")
  body.remove("api_token")
  body.remove("token")
  body.remove("api_token_secret")
  body.remove("notion_version")
  body.remove("secrets")
  body.remove("id")
  body.remove("page_id")
  body.remove("database_id")
  body.remove("data_source_id")
  body.remove("block_id")
  body.remove("comment_id")
  body.remove("file_upload_id")
  body.remove("property_id")
  body.remove("query_id")
  body.remove("user_id")
  body.remove("view_id")
  body.remove("start_cursor")
  body.remove("page_size")
  body.remove("filter_properties")
  body.remove("include_transcript")
  body.remove("name")
  body.remove("status")
  body.remove("request_method")
  body.remove("http_method")
  body.remove("method")
  body.remove("path")
  body.remove("body")
  return body
}

fn __required_id(args, field, method) {
  let value = args.get(field) ?? args?.id
  if value == nil || trim(to_string(value)) == "" {
    return __err("invalid_args", method + " requires " + field)
  }
  return Ok(value)
}

fn __notion_api_url(api_base_url, path) {
  let base = trim(to_string(api_base_url))
  let clean_base = if base.ends_with("/") {
    base[0:len(base) - 1]
  } else {
    base
  }
  let clean_path = if to_string(path).starts_with("/") {
    to_string(path)
  } else {
    "/" + to_string(path)
  }
  return clean_base + clean_path
}

fn __notion_headers(cfg) {
  return {
    Authorization: "Bearer " + cfg.api_token,
    ["Content-Type"]: "application/json",
    ["Notion-Version"]: cfg.notion_version,
  }
}

fn __notion_request(method, url, body, cfg) {
  let response = try {
    http_request(
    method,
    url,
    {
    headers: __notion_headers(cfg),
    body: if body == nil {
    nil
  } else {
    json_stringify(body)
  },
  },
  )
  }
  if is_err(response) {
    return __err("transport", to_string(unwrap_err(response)))
  }
  let http_response = unwrap(response)
  let decoded = try {
    json_parse(http_response.body ?? "{}")
  }
  if is_err(decoded) {
    return __err("invalid_response", "Notion API returned invalid JSON")
  }
  let payload = unwrap(decoded)
  if http_response.status < 200 || http_response.status >= 300 {
    let response_headers = http_response?.headers ?? {}
    return Err(
      {
      status: http_response.status,
      code: payload?.code ?? "notion_error",
      message: payload?.message ?? ("Notion API request failed with status " + to_string(http_response.status)),
      request_id: response_headers.get("x-request-id") ?? response_headers.get("request-id"),
    },
    )
  }
  return payload
}

fn __sdk_client(cfg) {
  var client = new_client(__sdk_base_url(cfg.api_base_url), cfg.api_token)
  client.extra_headers = {["Notion-Version"]: cfg.notion_version}
  return client
}

fn __sdk_base_url(api_base_url) {
  let base = trim(to_string(api_base_url))
  if base.ends_with("/v1") {
    return base[0:len(base) - 3]
  }
  if base.ends_with("/v1/") {
    return base[0:len(base) - 4]
  }
  if base.ends_with("/") {
    return base[0:len(base) - 1]
  }
  return base
}

fn __sdk_result(result) {
  if is_ok(result) {
    return unwrap(result)
  }
  return __sdk_error(unwrap_err(result))
}

fn __sdk_error(error) {
  let text = to_string(error)
  let marker = " HTTP "
  let marker_index = text.index_of(marker)
  if marker_index < 0 {
    return __err("notion_error", text)
  }
  let detail = text[marker_index + len(marker):len(text)]
  let space = detail.index_of(" ")
  let status_text = if space < 0 {
    detail
  } else {
    detail[0:space]
  }
  let parsed_status = to_int(status_text)
  let status = parsed_status ?? 0
  let body_text = if space < 0 {
    ""
  } else {
    detail[space + 1:len(detail)]
  }
  let decoded = try {
    json_parse(body_text)
  }
  if is_ok(decoded) {
    let payload = unwrap(decoded)
    return Err(
      {
      status: status,
      code: payload?.code ?? "notion_error",
      message: payload?.message ?? text,
      request_id: nil,
    },
    )
  }
  return Err({status: status, code: "notion_error", message: text, request_id: nil})
}

fn __poll_state(state) {
  return if state == nil {
    {poll_cache: {}}
  } else {
    state + {poll_cache: state?.poll_cache ?? {}}
  }
}

fn __cursor_high_water(cursor, high_water_mark) {
  if cursor == nil {
    return nil
  }
  if type_of(cursor) == "string" {
    return cursor
  }
  return cursor.get(high_water_mark) ?? cursor?.after ?? cursor?.high_water ?? cursor?.last_seen
    ?? cursor?.last_edited_time
}

fn __advance_cursor(cursor, high_water_mark, max_seen) {
  if max_seen == nil {
    return cursor
  }
  var next = if cursor != nil && type_of(cursor) != "string" {
    cursor
  } else {
    {}
  }
  next[high_water_mark] = max_seen
  next.after = max_seen
  return next
}

fn __poll_max_batch_size(ctx, binding) {
  let value = ctx?.max_batch_size ?? binding?.max_batch_size
  if value == nil {
    return nil
  }
  if value < 0 {
    return 0
  }
  return value
}

fn __build_poll_event(binding, page, previous_snapshot) {
  let event_type = "page.content_updated"
  let last_edited_time = to_string(page.last_edited_time)
  let payload = {
    event_type: event_type,
    resource_id: to_string(page.id),
    parent_id: __parent_id(page),
    actor: __actor(page),
    occurred_at: last_edited_time,
    raw: page,
    polled: {
    resource: binding.resource,
    source_id: binding.resource_id,
    state_key: binding?.state_key,
    high_water_mark: binding.high_water_mark,
    before: previous_snapshot,
    after: page,
  },
  }
  return {
    kind: event_type,
    occurred_at: last_edited_time,
    dedupe_key: __dedupe_key(event_type, payload.resource_id, {}, payload),
    signature_status: {state: "unsigned"},
    payload: payload,
    headers: {},
  }
}

fn __normalize_poll_binding(binding) {
  let binding_id = binding?.binding_id ?? binding?.id ?? "poll"
  let poll = binding?.poll ?? binding?.config?.poll ?? binding?.source ?? {}
  let resource = poll?.resource ?? if poll?.database_id != nil {
    "database"
  } else {
    "data_source"
  }
  if resource != "data_source" && resource != "database" {
    return __err(
      "activation",
      "unsupported notion poll resource `" + to_string(resource)
      + "`; expected data_source or database",
    )
  }
  let resource_id = if resource == "data_source" {
    poll?.data_source_id ?? poll?.database_id
  } else {
    poll?.database_id ?? poll?.data_source_id
  }
  if resource_id == nil || resource_id == "" {
    return __err("activation", "notion poll binding `" + binding_id + "` requires a " + resource + " id")
  }
  let page_size = poll?.page_size ?? 100
  return Ok(
    binding
    + {
    binding_id: binding_id,
    resource: resource,
    resource_id: to_string(resource_id),
    high_water_mark: poll?.high_water_mark ?? "last_edited_time",
    page_size: if page_size < 1 {
    1
  } else {
    if page_size > 100 {
      100
    } else {
      page_size
    }
  },
    filter: poll?.filter,
    sorts: poll?.sorts ?? [],
    max_batch_size: poll?.max_batch_size ?? binding?.max_batch_size ?? binding?.config?.max_batch_size,
    state_key: poll?.state_key ?? poll?.cursor_state_key ?? binding?.state_key ?? binding?.config?.state_key,
    api_base_url: binding?.api_base_url ?? binding?.config?.api_base_url ?? poll?.api_base_url,
    api_token: binding?.api_token ?? binding?.token ?? binding?.secrets?.api_token ?? binding?.config?.api_token
    ?? binding?.config?.secrets?.api_token
    ?? poll?.api_token
    ?? poll?.token
    ?? poll?.secrets?.api_token,
    notion_version: binding?.notion_version ?? binding?.config?.notion_version ?? poll?.notion_version,
  },
  )
}

@complexity(allow)
fn __query_pages_since(binding, high_water) {
  var start_cursor = nil
  var pages = []
  while true {
    var filters = []
    if binding?.filter != nil {
      filters = filters + [binding.filter]
    }
    if high_water != nil {
      filters = filters
        + [{timestamp: binding.high_water_mark, [binding.high_water_mark]: {after: high_water}}]
    }
    let filter = if len(filters) == 0 {
      nil
    } else {
      if len(filters) == 1 {
        filters[0]
      } else {
        {and: filters}
      }
    }
    let sorts = if len(binding?.sorts ?? []) == 0 {
      [{timestamp: binding.high_water_mark, direction: "ascending"}]
    } else {
      binding.sorts
    }
    var args = {
      api_base_url: binding?.api_base_url,
      api_token: binding?.api_token,
      notion_version: binding?.notion_version,
      page_size: binding.page_size,
      sorts: sorts,
    }
    if filter != nil {
      args.filter = filter
    }
    if start_cursor != nil {
      args.start_cursor = start_cursor
    }
    let response = if binding.resource == "data_source" {
      call("data_sources.query", args + {data_source_id: binding.resource_id})
    } else {
      call("databases.query", args + {database_id: binding.resource_id})
    }
    if is_err(response) {
      return response
    }
    let payload = unwrap(response)
    pages = pages + payload?.results ?? []
    if !(payload?.has_more ?? false) {
      break
    }
    start_cursor = payload?.next_cursor
    if start_cursor == nil || start_cursor == "" {
      break
    }
  }
  return Ok(pages)
}
