import { activate, kinds, normalize_inbound, poll_tick, provider_id } from "../src/lib"

pipeline default() {
  assert(provider_id() == "notion", "provider id")
  assert(kinds() == ["webhook", "poll"], "trigger kinds")
  let active = activate([{id: "main"}])
  assert(active.bindings == 1, "activation counts bindings")
  let event = normalize_inbound({payload: {type: "page.updated", entity: {id: "page-123"}}})
  assert(event.provider == "notion", "normalized provider")
  assert(event.event == "page.updated", "normalized event")
  assert(event.resource_id == "page-123", "normalized resource")
  assert(poll_tick().events == [], "poll_tick default")
}
